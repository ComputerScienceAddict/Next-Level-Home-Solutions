# Supabase (get from Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# NicheData (for leads/notices sync; same data is imported into Supabase)
NICHEDATA_API_TOKEN=your_nichedata_api_token

# Optional: AI-powered SEO targeting recommendations (GET /api/seo-analyze)
