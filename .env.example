# Canonical site URL (used for SEO metadata, sitemap, robots.txt)
# Set this in production to your live domain (e.g. https://www.nextlevelrealestatesolutions.com)
NEXT_PUBLIC_SITE_URL=https://nextlevelhomesolutions.com

# Supabase (get from Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# NicheData (for leads/notices sync; same data is imported into Supabase)
# All 58 CA counties × record types; parallel fetch concurrency (default 24, max 64).
NICHEDATA_API_TOKEN=your_nichedata_api_token
# NICHE_SYNC_CONCURRENCY=32
# Pagination (Niche often returns ~24 per page; we auto-fetch next pages until exhausted)
# NICHE_EXPECTED_PAGE_SIZE=24
# NICHE_MAX_PAGES_PER_COUNTY_TYPE=120
# NICHE_NOTICES_PAGE_LIMIT=100
# If page=1 breaks your API: NICHE_SEND_PAGE_QUERY=0

# Optional: AI-powered SEO (seo-analyze, seo-generate)
# OPENAI_API_KEY=sk-...

# Optional: Google Gemini (alternative to OpenAI)
# GEMINI_API_KEY=AIza...

# Lead form emails (Gmail SMTP — use an App Password, not your normal password)
# GMAIL_ADDRESS=your-sending@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Admin dashboard (/admin, /admin/seo) — required in production
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=use-a-long-random-secret
# ADMIN_SESSION_SECRET=another-long-random-string-for-signing-cookies
