# Supabase (get from Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# NicheData (for leads/notices sync; same data is imported into Supabase)
NICHEDATA_API_TOKEN=your_nichedata_api_token

# Optional: AI-powered SEO (seo-analyze, seo-generate)
# OPENAI_API_KEY=sk-...

# Optional: Google Gemini (alternative to OpenAI)
# GEMINI_API_KEY=AIza...
